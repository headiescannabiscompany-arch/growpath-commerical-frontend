{
  "name": "growpath-commercial-frontend",
  "version": "1.0.0",
  "description": "GrowPath Commercial Frontend - Professional Operations & Compliance Platform",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=20.19.4",
    "npm": ">=10.8.0"
  },
  "scripts": {
    "guard:contamination": "node scripts/guard-contamination.cjs",
    "guard:client": "node scripts/guard-client-wrapper.cjs",
    "guard:tool-journal-flow": "node scripts/guard-tool-journal-flow.cjs",
    "guard:tool-keys": "node scripts/guard-tool-keys.cjs",
    "validate:toolrun-contract": "node scripts/validate-toolrun-contract.cjs",
    "validate:source-record-contract": "node scripts/validate-source-record-contract.cjs",
    "validate:product-ingredient-contract": "node scripts/validate-product-ingredient-contract.cjs",
    "validate:nutrient-recipe-contract": "node scripts/validate-nutrient-recipe-contract.cjs",
    "validate:crop-profile-contract": "node scripts/validate-crop-profile-contract.cjs",
    "validate:tool-result-surface-contract": "node scripts/validate-tool-result-surface-contract.cjs",
    "validate:ownership-contract": "node scripts/validate-ownership-contract.cjs",
    "validate:soil-nutrient-tools-contract": "node scripts/validate-soil-nutrient-tools-contract.cjs",
    "validate:diagnosis-ipm-contract": "node scripts/validate-diagnosis-ipm-contract.cjs",
    "validate:genetics-pheno-contract": "node scripts/validate-genetics-pheno-contract.cjs",
    "validate:propagation-tc-contract": "node scripts/validate-propagation-tc-contract.cjs",
    "validate:harvest-history-contract": "node scripts/validate-harvest-history-contract.cjs",
    "validate:business-production-contract": "node scripts/validate-business-production-contract.cjs",
    "validate:visual-polish-contract": "node scripts/validate-visual-polish-contract.cjs",
    "inventory:ai-functions": "node scripts/inventory-ai-functions.cjs",
    "guard:telemetry-api": "node scripts/guard-telemetry-api.cjs",
    "validate:facility-context": "node scripts/validate-facility-context.cjs",
    "schema:install": "node scripts/install-ai-schema-pack.cjs",
    "schema:preflight": "node scripts/check-ai-schema-pack.cjs",
    "verify:dewpoint-fixture": "node scripts/verify-dewpoint-fixture.cjs",
    "guard": "npm run guard:contamination && npm run guard:client && npm run guard:tool-journal-flow && npm run guard:tool-keys && npm run validate:toolrun-contract && npm run validate:source-record-contract && npm run validate:product-ingredient-contract && npm run validate:nutrient-recipe-contract && npm run validate:crop-profile-contract && npm run validate:tool-result-surface-contract && npm run validate:ownership-contract && npm run validate:soil-nutrient-tools-contract && npm run validate:diagnosis-ipm-contract && npm run validate:genetics-pheno-contract && npm run validate:propagation-tc-contract && npm run validate:harvest-history-contract && npm run validate:business-production-contract && npm run validate:visual-polish-contract && npm run inventory:ai-functions && npm run validate:id-policy && npm run validate:facility-context && npm run guard:telemetry-api && npm run verify:dewpoint-fixture && npm run verify:qa-seed-system:planning && npm run verify:plant-id-qa-catalog:planning && npm run verify:diagnosis-ipm-qa-catalog:planning && npm run verify:living-soil-labs-commerce-qa-catalog:planning && npm run verify:facility-simulator-qa-catalog:planning && npm run verify:delivery",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "node scripts/render-static-build.cjs",
    "export:web:production": "node scripts/export-production-web.cjs",
    "export:store-assets": "node scripts/export-store-assets.cjs",
    "lint": "eslint \"src/{app,api,auth,components,entitlements,hooks,ui,utils}/**/*.{js,jsx,ts,tsx}\"",
    "lint:ci": "eslint \"src/{app,api,auth,components,entitlements,hooks,ui,utils}/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"src/{app,api,auth,components,entitlements,hooks,ui,utils}/**/*.{js,jsx,ts,tsx}\" --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json}\"",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "check:sensitive-copy": "node scripts/check-sensitive-copy.js",
    "drift:scan": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem .\\src -Recurse -File -Include *.js,*.jsx,*.ts,*.tsx | Where-Object { $_.FullName -notlike '*\\src\\api\\uriToBlob.ts' } | Select-String -Pattern '\\bfetch\\s*\\(|\\baxios\\b|\\bXMLHttpRequest\\b' | Where-Object { $_.Path -notlike '*\\src\\api\\client.ts' -and $_.Path -notlike '*\\src\\api\\apiRequest.ts' } | Where-Object { $_.Line -notmatch '\\bapiRequest\\b' } | Select-Object Path,LineNumber,Line | Sort-Object Path,LineNumber\"",
    "normalize:mojibake": "node scripts/normalize-mojibake.mjs",
    "verify:delivery": "node scripts/verify-delivery.mjs",
    "scan:release": "node scripts/scan-release.cjs",
    "scan:full": "node scripts/full-scan.mjs",
    "scan:full:strict": "node scripts/full-scan.mjs --strict",
    "audit:full-surface": "node scripts/audit-full-surface.cjs",
    "audit:growpath-system": "node scripts/audit-growpath-system.cjs",
    "release:preflight": "node scripts/release-preflight.cjs",
    "release:preflight:strict": "node scripts/release-preflight.cjs --strict",
    "verify:sentry-dsn": "node scripts/verify-sentry-dsn.cjs",
    "verify:web-seo": "node scripts/verify-web-seo.cjs",
    "seo:submit:indexnow": "node scripts/submit-indexnow.cjs",
    "verify:live-urls": "node scripts/verify-live-urls.cjs",
    "verify:email-delivery-config": "node scripts/verify-email-delivery-config.cjs",
    "verify:email-delivery-config:strict": "node scripts/verify-email-delivery-config.cjs --strict",
    "verify:live-test-packs:sources": "node scripts/verify-live-test-pack-sources.cjs",
    "verify:live-test-packs:sources:planning": "node scripts/verify-live-test-pack-sources.cjs --allow-placeholders",
    "verify:qa-seed-system": "node scripts/verify-qa-seed-system.cjs",
    "verify:qa-seed-system:planning": "node scripts/verify-qa-seed-system.cjs --allow-planning",
    "verify:plant-id-qa-catalog": "node scripts/verify-plant-id-qa-catalog.cjs",
    "verify:plant-id-qa-catalog:planning": "node scripts/verify-plant-id-qa-catalog.cjs --allow-planning",
    "verify:diagnosis-ipm-qa-catalog": "node scripts/verify-diagnosis-ipm-qa-catalog.cjs",
    "verify:diagnosis-ipm-qa-catalog:planning": "node scripts/verify-diagnosis-ipm-qa-catalog.cjs --allow-planning",
    "verify:living-soil-labs-commerce-qa-catalog": "node scripts/verify-living-soil-labs-commerce-qa-catalog.cjs",
    "verify:living-soil-labs-commerce-qa-catalog:planning": "node scripts/verify-living-soil-labs-commerce-qa-catalog.cjs --allow-planning",
    "verify:facility-simulator-qa-catalog": "node scripts/verify-facility-simulator-qa-catalog.cjs",
    "verify:facility-simulator-qa-catalog:planning": "node scripts/verify-facility-simulator-qa-catalog.cjs --allow-planning",
    "verify:facility-simulator-qa-catalog:acceptance": "node scripts/verify-facility-simulator-qa-catalog.cjs --require-acceptance",
    "build:facility-simulator-qa-fixture": "node scripts/build-facility-simulator-qa-fixture.cjs",
    "validate:id-policy": "node scripts/validate-id-policy.cjs",
    "verify:connected-workflows": "node scripts/verify-connected-workflows.cjs",
    "verify:codex-workflow": "node scripts/verify-codex-workflow.cjs",
    "verify:data-rights:live": "node scripts/verify-data-rights-live.cjs",
    "release:builds:dry-run": "node scripts/run-production-builds.cjs",
    "release:builds": "node scripts/run-production-builds.cjs --execute",
    "release:machine": "node scripts/run-release-machine-gates.cjs",
    "release:go-no-go": "node scripts/release-go-no-go.cjs",
    "release:record-evidence": "node scripts/record-release-evidence.cjs",
    "verify:manual": "npm run verify:manual:checks && npm run export:web:production",
    "verify:manual:checks": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-before-manual.ps1",
    "verify:deferred-user-checks": "node scripts/run-deferred-user-verifications.cjs",
    "test": "npm run inventory:ui-routes && jest --runInBand",
    "test:backend": "jest --config jest.backend.config.cjs --runInBand backend/routes/ai.call.test.js backend/llm/provider.test.js backend/utils/ecCorrection.test.js backend/entitlements.test.js",
    "test:backend:all": "jest --config jest.backend.config.cjs --runInBand",
    "test:ci": "npm run inventory:ui-routes && jest --runInBand --forceExit",
    "nightly": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/nightly.ps1",
    "test:live": "node scripts/test-live.js",
    "backend:start": "node scripts/start-backend.js",
    "inventory:backend-routes": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export-backend-routes.ps1",
    "inventory:ui-routes": "node scripts/inventory-ui-routes.cjs",
    "inventory:tool-surface": "node scripts/inventory-tool-surface.cjs",
    "inventory:capabilities": "node scripts/inventory-capability-keys.cjs",
    "validate:v1-matrix": "node scripts/validate-v1-feature-matrix.cjs",
    "validate:v1-ui-surface": "node scripts/validate-v1-ui-surface.cjs",
    "validate:frontend-runtime-contract": "node scripts/validate-frontend-runtime-contract.cjs",
    "validate:backend-route-contract": "node scripts/validate-backend-route-contract.cjs",
    "acceptance": "node scripts/run-acceptance.js",
    "acceptance:live": "USE_LIVE_BACKEND=true ACCEPTANCE_COMMANDS='node --test --import ./tests/setup_fetch_spy.js tests/**/*.test.js' node scripts/run-acceptance.js",
    "postacceptance:live": "npx playwright test tests/playwright",
    "e2e": "node scripts/run-playwright-expo.cjs",
    "e2e:ui": "playwright test --ui"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
