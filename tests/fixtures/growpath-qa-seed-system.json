      "mediaUrl",
      "creator",
      "licenseId",
      "attributionText",
      "retrievedAt",
      "rightsReviewedAt",
      "intendedUseApproved"
    ]
  },
  "sourceCandidates": [
    {
      "id": "inaturalist",
      "name": "iNaturalist observations and photos",
      "status": "conditional_review_required",
      "sourceUrl": "https://www.inaturalist.org/",
      "termsUrl": "https://www.inaturalist.org/pages/terms",
      "apiUrl": "https://api.inaturalist.org/v2/docs/",
      "licenseReviewRequired": true,
      "reliabilityTier": "B_context_limited_official_source",
      "crossCheckRequired": true,
      "lastReviewedAt": "2026-07-20",
      "trustedFor": [
        "candidate crop and lookalike observations",
        "taxon metadata leads",
        "image-level license discovery"
      ],
      "notTrustedFor": [
        "cultivar inference from appearance",
        "confirmed plant diagnosis",
        "commercial AI training",
        "copying noncommercial or all-rights-reserved media"
      ],
      "requirements": [
        "review terms at execution time",
        "record the license for each photo separately from observation metadata",
        "copy only media whose license permits the intended use",
        "retain creator attribution"
      ]
    },
    {
      "id": "plantvillage",
      "name": "PlantVillage Dataset",
      "status": "conditional_review_required",
      "sourceUrl": "https://github.com/spMohanty/PlantVillage-Dataset",
      "licenseReviewRequired": true,
      "reliabilityTier": "B_context_limited_dataset_source",
      "crossCheckRequired": true,
      "lastReviewedAt": "2026-07-20",
      "trustedFor": [
        "candidate controlled-background disease-image cases",
        "research label and crop coverage leads"
      ],
      "notTrustedFor": [
        "field-condition performance assumptions",
        "cannabis-specific diagnosis",
        "automatic commercial-use approval",
        "confirmed diagnosis without case context"
      ],
      "requirements": [
        "identify the governing dataset and image license",
        "approve the intended commercial QA use",
        "keep train/test leaf groups separated if used for benchmarking",
        "pair image labels with GrowPath evidence and alternatives"
      ]
    },
    {
      "id": "growpath_owner_media",
      "name": "GrowPathAI owner-supplied or commissioned media",
      "status": "preferred_pending_assets",
      "sourceUrl": "TODO_OWNER_MEDIA_SOURCE_REGISTRY_URL",
      "licenseReviewRequired": true,
      "reliabilityTier": "B_owner_source_for_owned_claims_only",
      "crossCheckRequired": true,
      "lastReviewedAt": "2026-07-20",
      "trustedFor": [
        "cannabis/hemp stage and harvested-flower QA",
        "Living Soil Labs product and merchandise fixtures",
        "application-specific failure and workflow cases"
      ],
      "notTrustedFor": [
        "unrecorded cultivar provenance",
        "unverified guaranteed analysis",
        "medical or pesticide claims"
      ],
      "requirements": [
        "record ownership or permission",
        "record creator and attribution preference",
        "record label or formula evidence separately from product photos"
      ]
    }
