  "commerceScenarios": [
    {
      "scenarioId": "draft_storefront_hidden",
      "requiredStates": ["draft product", "hidden storefront"],
      "expectedResult": "Unapproved products are not publicly purchasable."
    },
    {
      "scenarioId": "in_stock_cart",
      "requiredStates": ["configured variant", "in stock"],
      "expectedResult": "Selected variant enters the cart once with its recorded price and currency."
    },
    {
      "scenarioId": "out_of_stock_block",
      "requiredStates": ["configured variant", "out of stock"],
      "expectedResult": "Checkout is blocked without decrementing inventory."
    },
    {
      "scenarioId": "discount_apply",
      "requiredStates": ["eligible code", "eligible cart"],
      "expectedResult": "Recorded discount is applied once and retained on the order."
    },
    {
      "scenarioId": "discount_reject",
      "requiredStates": ["invalid or ineligible code"],
      "expectedResult": "Cart total is unchanged and the reason is shown."
    },
    {
      "scenarioId": "tax_calculation",
      "requiredStates": ["configured jurisdiction", "taxable cart"],
      "expectedResult": "Order retains the provider-calculated tax amount and jurisdiction evidence."
    },
    {
      "scenarioId": "shipping_calculation",
      "requiredStates": ["measured variant weights", "destination", "configured rate"],
      "expectedResult": "Order retains the selected shipping service, amount, and weight inputs."
    },
    {
      "scenarioId": "checkout_cancel",
      "requiredStates": ["test checkout session", "buyer cancellation"],
      "expectedResult": "No paid order or inventory decrement is recorded."
    },
    {
      "scenarioId": "paid_order",
      "requiredStates": ["test checkout session", "confirmed payment webhook"],
      "expectedResult": "One paid order is recorded and inventory changes once."
    },
    {
      "scenarioId": "order_cancellation",
      "requiredStates": ["cancellable order", "authorized owner action"],
      "expectedResult": "Cancellation reason, actor, timestamp, and inventory decision are retained."
    },
    {
      "scenarioId": "full_refund",
      "requiredStates": ["paid order", "confirmed refund event"],
      "expectedResult": "Refund amount, reason, event id, order status, and inventory decision are retained."
    },
    {
      "scenarioId": "order_history",
      "requiredStates": ["multiple order states"],
      "expectedResult": "Buyer and owner views show the same recorded product, variant, totals, payment, fulfillment, cancellation, and refund state."
    }
  ]
