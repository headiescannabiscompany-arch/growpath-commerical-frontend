{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Expo",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Expo web",
      "type": "shell",
      "command": "npm run web",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Dev: Backend + Frontend",
      "dependsOn": ["Backend: dev", "Frontend: Expo"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Test: all",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
