{
  "title": "GrowPathAIResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module",
    "intent",
    "confidence",
    "summary",
    "evidence",
    "possibleIssues",
    "recommendations",
    "warnings",
    "suggestedTags",
    "suggestedTasks",
    "linkedGrowData",
    "sourceObjects",
    "userApprovalRequired",
    "disclaimer"
  ],
  "properties": {
    "module": {
      "type": "string",
      "enum": [
        "diagnosis",
        "grow_aware_chat",
        "grow_log_auto_tagging",
        "plant_diagnosis_engine",
        "pheno_summary",
        "stress_summary",
        "tissue_culture",
        "soil_nutrients",
        "tool_run",
        "compliance",
        "planner"
      ]
    },
    "intent": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["label", "detail"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "detail": { "type": "string", "minLength": 1 },
          "sourceObjectId": { "type": "string" }
        }
      }
    },
    "possibleIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["issue", "category", "confidence"],
        "properties": {
          "issue": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "nextChecks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["title", "rationale"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "suggestedTags": { "type": "array", "items": { "type": "string" } },
    "suggestedTasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" },
          "priority": { "type": "string", "enum": ["low", "medium", "high"] },
          "dueAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "linkedGrowData": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "facilityId": { "type": "string" },
        "growId": { "type": "string" },
        "plantId": { "type": "string" },
        "roomId": { "type": "string" },
        "logId": { "type": "string" },
        "taskId": { "type": "string" },
        "recipeId": { "type": "string" },
        "toolRunId": { "type": "string" }
      }
    },
    "sourceObjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "id"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "userApprovalRequired": { "type": "boolean" },
    "disclaimer": { "type": "string", "minLength": 1 }
  }
}
