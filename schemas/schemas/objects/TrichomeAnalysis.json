{
  "title": "TrichomeAnalysis",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "facilityId", "growId", "images", "zones", "distribution", "confidence", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "facilityId": { "type": "string", "minLength": 1 },
    "growId": { "type": "string", "minLength": 1 },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "zones": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clear", "cloudy", "amber"],
      "properties": {
        "clear": { "type": "number", "minimum": 0, "maximum": 1 },
        "cloudy": { "type": "number", "minimum": 0, "maximum": 1 },
        "amber": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "notes": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "deletedAt": {
      "anyOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    }
  }
}
