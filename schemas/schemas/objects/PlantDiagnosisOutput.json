{
  "title": "PlantDiagnosisOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagnosisClass",
    "likelyIssues",
    "patternSummary",
    "rootZoneSummary",
    "environmentSummary",
    "numberSummary",
    "recommendations",
    "tasksToCreate",
    "tags",
    "urgency",
    "disclaimer"
  ],
  "properties": {
    "diagnosisClass": { "type": "string", "minLength": 1 },
    "likelyIssues": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "patternSummary": { "type": "string" },
    "rootZoneSummary": { "type": "string" },
    "environmentSummary": { "type": "string" },
    "numberSummary": { "type": "string" },
    "recommendations": { "type": "array", "items": { "type": "string" } },
    "tasksToCreate": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "urgency": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
    "disclaimer": { "type": "string", "minLength": 1 }
  }
}
